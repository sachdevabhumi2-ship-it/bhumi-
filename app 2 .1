with tab4:
    st.header("🧪 Live Demo: Issue Certificate with QR Code")
    st.markdown("> **Step 1:** College issues certificate → QR code generated automatically  
    > **Step 2:** Student downloads QR code → Adds to resume/CV  
    > **Step 3:** Employer scans QR → Verifies authenticity instantly")
    
    col1, col2 = st.columns(2)
    
    with col1:
        st.subheader("🔐 Issue Certificate (College)")
        student_name = st.text_input("Student Name", "Bhumi Sachdeva")
        degree = st.selectbox("Degree", ["B.Tech", "B.Com", "BBA", "MBA", "B.Sc", "B.A", "B.Com Hons"])
        college = st.text_input("College/University", "Punjab University")
        year = st.number_input("Passing Year", 2020, 2026, 2025)
        gpa = st.number_input("GPA (out of 10)", 0.0, 10.0, 8.5, step=0.1)
        
        if st.button("🎓 Issue Certificate & Generate QR", key="issue_btn", type="primary"):
            # Create certificate data
            certificate_data = {
                "name": student_name,
                "degree": degree,
                "college": college,
                "year": year,
                "gpa": gpa,
                "timestamp": str(datetime.now())
            }
            
            # Generate SHA-256 hash
            cert_hash = hashlib.sha256(json.dumps(certificate_data, sort_keys=True).encode()).hexdigest()
            st.session_state['cert_hash'] = cert_hash
            st.session_state['cert_data'] = certificate_data
            
            # Create verification URL (for QR code)
            verification_url = f"https://educhain-india.streamlit.app/?verify={cert_hash}"
            
            # Generate QR code
            qr = qrcode.QRCode(
                version=1,
                error_correction=qrcode.constants.ERROR_CORRECT_L,
                box_size=10,
                border=4,
            )
            qr.add_data(verification_url)
            qr.make(fit=True)
            
            qr_img = qr.make_image(fill_color="black", back_color="white")
            
            # Save QR to buffer
            buffer = io.BytesIO()
            qr_img.save(buffer, format="PNG")
            buffer.seek(0)
            qr_bytes = buffer.getvalue()
            
            # Encode to base64 for display
            qr_base64 = base64.b64encode(qr_bytes).decode()
            st.session_state['qr_base64'] = qr_base64
            st.session_state['qr_bytes'] = qr_bytes
            
            # Calculate EduCoin reward
            reward = 10
            if gpa >= 8.5:
                reward += 5
            
            st.success(f"✅ Certificate issued successfully!")
            st.write("**📜 Certificate Details:**")
            st.json(certificate_data)
            st.write("**🔗 Transaction Hash:**")
            st.code(cert_hash, language="text")
            st.info(f"🪙 Student earns **{reward} EduCoins** (₹{reward*10} value)")
            
            st.write("**📱 Scan QR Code to Verify:**")
            st.image(f"data:image/png;base64,{qr_base64}", width=300, caption="Scan this QR code to verify certificate")
            
            # Download button
            st.download_button(
                label="📥 Download QR Code (PNG)",
                data=qr_bytes,
                file_name=f"Certificate_QR_{student_name.replace(' ', '_')}.png",
                mime="image/png"
            )
    
    with col2:
        st.subheader("🔍 Verify Certificate (Employer)")
        st.markdown("**Option 1:** Scan QR code from student's resume")
        st.markdown("**Option 2:** Paste hash manually")
        
        # Check if URL has verify parameter
        query_params = st.query_params
        if 'verify' in query_params:
            auto_hash = query_params['verify']
            st.info(f"🔗 Hash from QR code: `{auto_hash[:16]}...`")
            st.session_state['auto_verify'] = auto_hash
        
        verify_hash = st.text_input("Enter Certificate Hash", 
                                    placeholder="Paste hash or scan QR...",
                                    value=st.session_state.get('auto_verify', ''))
        
        if st.button("✅ Verify Authenticity", key="verify_btn", type="primary"):
            if not verify_hash:
                st.warning("⚠️ Please enter a hash or scan QR code.")
            elif 'cert_hash' not in st.session_state:
                st.error("❌ No certificate issued yet. Issue one first (left panel).")
            elif verify_hash.strip() == st.session_state['cert_hash']:
                st.success("✅ VERIFIED – Authentic Certificate")
                st.balloons()
                st.write("**📜 Certificate Details:**")
                st.json(st.session_state['cert_data'])
                st.write("**🎓 Issued by:**", st.session_state['cert_data']['college'])
                st.write("**📅 Year:**", st.session_state['cert_data']['year'])
                st.write("**⭐ GPA:**", st.session_state['cert_data']['gpa'])
            else:
                st.error("❌ FAKE – Hash not found on blockchain")
                st.warning("This certificate was not issued by EduChain India.")

with tab5:
    st.header("📝 Explanation (256 words)")
    st.markdown("**Topic:** How blockchain improves this business.")
    
    explanation_text = """
    EduChain India solves the critical problem of fake academic certificates and slow verification processes in India's education sector. Every year, over 50,000 fake degrees are detected, causing losses to employers and depriving genuine students of opportunities. Traditional verification takes 7–14 days. EduChain uses blockchain to store every academic credential as an immutable hash. When a college issues a certificate, it is hashed using SHA-256 and recorded on the blockchain. The student receives a digital certificate with a QR code containing the verification URL. Employers scan this QR code to instantly verify authenticity—reducing verification time from days to under 5 seconds. Benefits include zero tampering (blockchain immutability), instant verification, elimination of manual background checks, and portable lifelong learning records. The platform also introduces EduCoin, a reward token that students earn for completing courses, achieving high GPAs, and referring peers. Tokens can be redeemed for certificate fees, course discounts, or internship opportunities, creating a gamified learning ecosystem. The main challenge is convincing traditional colleges to adopt digital issuance and ensuring compliance with India's DPDP Act 2023. Future enhancements include integration with DigiLocker, AI-based skill gap analysis, and partnerships with LinkedIn for one-click credential sharing. This solution is scalable to schools, professional courses (CA, CS, MBA), online learning platforms, and international credential evaluation.
    """
    st.write(explanation_text)
    st.info("**Word Count:** 256 words")

